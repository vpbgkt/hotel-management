# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel?schema=public"

# Redis (optional — app works without it)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_ENABLED="false"

# Hotel identity
HOTEL_ID=""  # Set after first hotel is created
APP_NAME="My Hotel"
APP_URL="http://localhost:3000"
APP_EMAIL="noreply@localhost"

# JWT Secrets (change in production!)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# Environment
NODE_ENV="development"
PORT=4000

# Razorpay (get from razorpay.com — Indian payments only)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# SMS Provider (future)
SMS_API_KEY=""
SMS_SENDER_ID=""

# Email (SMTP) - set to enable real email sending
# Works with any SMTP provider: Gmail, SendGrid, Resend, Amazon SES, etc.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="${APP_NAME} <noreply@yourdomain.com>"
